---
import Layout from '../../../layouts/Layout.astro';
import skateparksData from '../../../data/skate-parks.json';

export function getStaticPaths() {
  const grouped: Record<string, Record<string, any[]>> = {};
  
  for (const item of skateparksData) {
    const state = (item.state as string).toLowerCase();
    const suburb = (item.suburb as string).toLowerCase()
  .replace(/\s+/g, '-')
  .replace(/-cbd$/, '')
  .replace(/-city$/, '')
  .replace(/-metro$/, '')
  .replace(/-centre$/, '');
    if (!grouped[state]) grouped[state] = {};
    if (!grouped[state][suburb]) grouped[state][suburb] = [];
    grouped[state][suburb].push(item);
  }

  const paths: any[] = [];
  for (const state in grouped) {
    for (const suburb in grouped[state]) {
      paths.push({
        params: { state, suburb },
        props: { 
          gyms: grouped[state][suburb], 
          state: state.toUpperCase(), 
          suburb: grouped[state][suburb][0].suburb 
        }
      });
    }
  }
  return paths;
}

const { skateparks, state, suburb } = Astro.props;
const stateNames: Record<string, string> = {
  NSW: 'New South Wales', VIC: 'Victoria', QLD: 'Queensland',
  WA: 'Western Australia', SA: 'South Australia', TAS: 'Tasmania',
  ACT: 'Australian Capital Territory', NT: 'Northern Territory'
};
const stateName = stateNames[state] || state;
---

<Layout 
  title={`Skate Parks Near Me in ${suburb}, ${state}`} 
  description={`Find ${skateparks.length} skate parks and skateboarding areas near you in ${suburb}, ${stateName}. Ratings, addresses and directions.`}
>

  <div class="dir-page-hero">
    <div class="container">
      <p style="color:#40916C; font-size:0.85rem; margin-bottom:0.5rem;">
        <a href="/skate-parks" style="color:#40916C;">All Gyms</a> →
        <a href={`/skate-parks/${state.toLowerCase()}`} style="color:#40916C;">{stateName}</a> →
        {suburb}
      </p>
      <h1>🏋️ Skate Parks Near Me in {suburb}, {state}</h1>
      <p>{skateparks.length} skate parks and skateboarding areas in {suburb}</p>
    </div>
  </div>

  <div class="results-grid" style="padding-top: 2rem;">
    {skateparks.map((gym: any) => (
      <a href={gym.maps_url} target="_blank" rel="noopener" class="result-card">
        <div class="result-card-name">{gym.name}</div>
        <div class="result-card-loc">📍 {gym.address}</div>
        {gym.rating && <div class="result-card-rating">⭐ {gym.rating} ({gym.total_ratings?.toLocaleString()} reviews)</div>}
        <span class="result-card-state">{state}</span>
      </a>
    ))}
  </div>

  <div class="ad-slot" style="max-width:1100px; margin: 2rem auto;">Google AdSense</div>

  <div style="max-width:1100px; margin: 0 auto 3rem; padding: 0 2rem;">
    <h2 style="font-family:'Syne',sans-serif; font-size:1.2rem; margin-bottom:1rem;">
      More gyms in {stateName}
    </h2>
    <p>
      <a href={`/skate-parks/${state.toLowerCase()}`} style="color:var(--green);">
        Browse all gyms in {stateName} →
      </a>
    </p>
  </div>

</Layout>

<style>
  .result-card-rating { font-size: 0.78rem; color: var(--mid); }
</style>