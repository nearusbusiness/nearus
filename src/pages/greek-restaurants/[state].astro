---
import Layout from '../../layouts/Layout.astro';
import greekRestaurantsData from '../../data/greek-restaurants.json';
export function getStaticPaths() {
  const states = [...new Set(greekRestaurantsData.map((g: any) => g.state))];
  return states.map(state => ({
    params: { state: (state as string).toLowerCase() },
    props: { state }
  }));
}
const { state } = Astro.props;
const items = greekRestaurantsData.filter((g: any) => g.state === state);
const stateNames: Record<string, string> = {
  NSW: 'New South Wales', VIC: 'Victoria', QLD: 'Queensland',
  WA: 'Western Australia', SA: 'South Australia', TAS: 'Tasmania',
  ACT: 'Australian Capital Territory', NT: 'Northern Territory'
};
const stateName = stateNames[state] || state;
---
<Layout
  title={`Greek Restaurants in ${stateName} — Find ${items.length} Greek Restaurants | NearUs`}
  description={`Find ${items.length} greek restaurants in ${stateName}. Browse by suburb with ratings, addresses and directions.`}
>
  <div class="dir-page-hero">
    <div class="container">
      <p style="color:#40916C; font-size:0.85rem; margin-bottom:0.5rem;">
        <a href="/greek-restaurants" style="color:#40916C;">All Greek Restaurants</a> → {stateName}
      </p>
      <h1>Greek Restaurants in {stateName}</h1>
      <p>Find {items.length} greek restaurants across {stateName}</p>
    </div>
  </div>
  <div class="results-grid" style="padding-top: 2rem;">
    {items.map((item: any) => (
      <a href={item.maps_url} target="_blank" rel="noopener" class="result-card">
        <div class="result-card-name">{item.name}</div>
        <div class="result-card-loc">📍 {item.address}</div>
        {item.rating && <div class="result-card-rating">⭐ {item.rating} ({item.reviews?.toLocaleString()} reviews)</div>}
        <span class="result-card-state">{state}</span>
      </a>
    ))}
  </div>
  <div class="ad-slot" style="max-width:1100px; margin: 2rem auto;">Google AdSense</div>
</Layout>
<style>
  .result-card-rating { font-size: 0.78rem; color: var(--mid); }
</style>
