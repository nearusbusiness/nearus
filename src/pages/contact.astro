---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact NearUs" description="Get in touch with the NearUs team.">
  <div class="container" style="max-width:720px; padding: 4rem 2rem;">
    <h1 style="font-family:'Syne',sans-serif; font-size:2rem; margin-bottom:1.5rem;">Contact Us</h1>
    <p style="color:var(--mid); line-height:1.8; margin-bottom:2rem;">Got a question, found an incorrect listing, or want to get in touch? We'd love to hear from you.</p>
    <div style="background:var(--white); border:1px solid var(--border); border-radius:12px; padding:2rem;">
      <p style="font-weight:600; margin-bottom:0.5rem;">Email</p>
      <a href="mailto:hello@nearus.com.au" style="color:var(--green); font-size:1.1rem;">nearus.business@outlook.com</a>
      <hr style="border:none; border-top:1px solid var(--border); margin:1.5rem 0;" />
      <p style="font-weight:600; margin-bottom:0.5rem;">Listing issues</p>
      <p style="color:var(--mid); line-height:1.8;">If a listing is incorrect or missing, email us with the business name, suburb and state and we'll get it updated.</p>
    </div>
  </div>
</Layout>