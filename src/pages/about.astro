---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About NearUs" description="NearUs is Australia's most comprehensive local directory.">
  <div class="container" style="max-width:720px; padding: 4rem 2rem;">
    <h1 style="font-family:'Syne',sans-serif; font-size:2rem; margin-bottom:1.5rem;">About NearUs</h1>
    <p style="color:var(--mid); line-height:1.8; margin-bottom:1rem;">NearUs is Australia's local directory — built to help Australians find what they need, wherever they are.</p>
    <p style="color:var(--mid); line-height:1.8; margin-bottom:1rem;">We cover gyms, free camping, dog parks, restaurants, beaches, medical centres, and much more — across every suburb and every state in Australia.</p>
    <p style="color:var(--mid); line-height:1.8; margin-bottom:1rem;">Our directory is updated regularly to ensure you're always finding accurate, current listings near you.</p>
    <p style="color:var(--mid); line-height:1.8;">Built in Australia, for Australians.</p>
  </div>
</Layout>