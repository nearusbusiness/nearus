---
import Layout from '../../../layouts/Layout.astro';
import fastfoodData from '../../../data/fast-food.json';

export function getStaticPaths() {
  const grouped: Record<string, Record<string, any[]>> = {};
  
  for (const item of fastfoodData) {
    const state = (item.state as string).toLowerCase();
    if (!item.suburb) continue;
    if (!item.state) continue;
    const rawSuburb = (item.suburb as string).trim();
    if (rawSuburb.match(/^\d/) || rawSuburb.includes('/') || rawSuburb.length > 50) continue;
    const suburb = rawSuburb.toLowerCase()
  .replace(/\s+/g, '-')
  .replace(/-cbd$/, '')
  .replace(/-city$/, '')
  .replace(/-metro$/, '')
  .replace(/-centre$/, '');
    if (!grouped[state]) grouped[state] = {};
    if (!grouped[state][suburb]) grouped[state][suburb] = [];
    grouped[state][suburb].push(item);
  }

  const paths: any[] = [];
  for (const state in grouped) {
    for (const suburb in grouped[state]) {
      paths.push({
        params: { state, suburb },
        props: { 
          fastfood: grouped[state][suburb], 
          state: state.toUpperCase(), 
          suburb: grouped[state][suburb][0].suburb 
        }
      });
    }
  }
  return paths;
}

const { fastfood, state, suburb } = Astro.props;
const stateNames: Record<string, string> = {
  NSW: 'New South Wales', VIC: 'Victoria', QLD: 'Queensland',
  WA: 'Western Australia', SA: 'South Australia', TAS: 'Tasmania',
  ACT: 'Australian Capital Territory', NT: 'Northern Territory'
};
const stateName = stateNames[state] || state;
---

<Layout 
  title={`Fast Food Near Me in ${suburb}, ${state}`} 
  description={`Find ${fastfood.length} Find fast food and takeaway near you across every state in Australia. near you in ${suburb}, ${stateName}. Ratings, addresses and directions.`}
>

  <div class="dir-page-hero">
    <div class="container">
      <p style="color:#40916C; font-size:0.85rem; margin-bottom:0.5rem;">
        <a href="/fast-food" style="color:#40916C;">All Gyms</a> →
        <a href={`/fast-food/${state.toLowerCase()}`} style="color:#40916C;">{stateName}</a> →
        {suburb}
      </p>
      <h1>🏋️ Fast Food Near Me in {suburb}, {state}</h1>
      <p>{fastfood.length} Find fast food and takeaway near you across every state in Australia. in {suburb}</p>
    </div>
  </div>

  <div class="results-grid" style="padding-top: 2rem;">
    {fastfood.map((item: any) => (
      <a href={item.maps_url} target="_blank" rel="noopener" class="result-card">
        <div class="result-card-name">{item.name}</div>
        <div class="result-card-loc">📍 {item.address}</div>
        {item.rating && <div class="result-card-rating">⭐ {item.rating} ({item.total_ratings?.toLocaleString()} reviews)</div>}
        <span class="result-card-state">{state}</span>
      </a>
    ))}
  </div>

  <div class="ad-slot" style="max-width:1100px; margin: 2rem auto;">Google AdSense</div>

  <div style="max-width:1100px; margin: 0 auto 3rem; padding: 0 2rem;">
    <h2 style="font-family:'Syne',sans-serif; font-size:1.2rem; margin-bottom:1rem;">
      More gyms in {stateName}
    </h2>
    <p>
      <a href={`/fast-food/${state.toLowerCase()}`} style="color:var(--green);">
        Browse all gyms in {stateName} →
      </a>
    </p>
  </div>

</Layout>

<style>
  .result-card-rating { font-size: 0.78rem; color: var(--mid); }
</style>