---
import Layout from '../layouts/Layout.astro';
import gymsData from '../data/gyms.json';
import campingData from '../data/camping.json';
import dogParksData from '../data/dog-parks.json';
import marketsData from '../data/markets.json';
import poolsData from '../data/pools.json';
import skateParksData from '../data/skate-parks.json';
import playgroundsData from '../data/playgrounds.json';
import tennisData from '../data/tennis-courts.json';
import evData from '../data/ev-charging.json';
import librariesData from '../data/libraries.json';

const gymCount = gymsData.length;
const campingCount = campingData.length;
const dogParksCount = dogParksData.length;
const marketsCount = marketsData.length;
const poolsCount = poolsData.length;
const skateParksCount = skateParksData.length;
const playgroundsCount = playgroundsData.length;
const tennisCount = tennisData.length;
const evCount = evData.length;
const librariesCount = librariesData.length;
const totalCount = gymCount + campingCount + dogParksCount + marketsCount + poolsCount + skateParksCount + playgroundsCount + tennisCount + evCount + librariesCount;

const states = ['NSW','VIC','QLD','WA','SA','TAS','ACT','NT'];

const stateCounts = {
  gyms: Object.fromEntries(states.map(s => [s, (gymsData as any[]).filter(g => g.state === s).length])),
  camping: Object.fromEntries(states.map(s => [s, (campingData as any[]).filter(g => g.state === s).length])),
  dogParks: Object.fromEntries(states.map(s => [s, (dogParksData as any[]).filter(g => g.state === s).length])),
  markets: Object.fromEntries(states.map(s => [s, (marketsData as any[]).filter(g => g.state === s).length])),
  pools: Object.fromEntries(states.map(s => [s, (poolsData as any[]).filter(g => g.state === s).length])),
  skateParks: Object.fromEntries(states.map(s => [s, (skateParksData as any[]).filter(g => g.state === s).length])),
  playgrounds: Object.fromEntries(states.map(s => [s, (playgroundsData as any[]).filter(g => g.state === s).length])),
  tennis: Object.fromEntries(states.map(s => [s, (tennisData as any[]).filter(g => g.state === s).length])),
  ev: Object.fromEntries(states.map(s => [s, (evData as any[]).filter(g => g.state === s).length])),
  libraries: Object.fromEntries(states.map(s => [s, (librariesData as any[]).filter(g => g.state === s).length])),
}
---

<Layout title="Australia's Local Directory" description="Find gyms, free camping, dog parks, markets and more across every state in Australia.">

  <section class="hero">
    <div class="hero-eyebrow">🇦🇺 Australia's Local Directory</div>
    <h1>Find anything,<br><em>near you</em> in Australia</h1>
    <p class="hero-sub">Gyms, camping spots, dog parks, markets and more — every suburb, every state, all in one place.</p>

    <div class="search-wrap">
      <input type="text" id="hero-search" placeholder="Search gyms, parks, markets..." />
      <button class="search-btn" onclick="heroSearch()">Search</button>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num" id="total-count">{totalCount.toLocaleString()}+</div>
        <div class="hero-stat-label">Listings</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">10</div>
        <div class="hero-stat-label">Directories</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">All States</div>
        <div class="hero-stat-label">Covered</div>
      </div>
    </div>
  </section>

  <div class="state-strip">
    <div class="state-strip-inner">
      <div class="state-pill active" onclick="filterState('all', this)">All States</div>
      <div class="state-pill" onclick="filterState('NSW', this)">NSW</div>
      <div class="state-pill" onclick="filterState('VIC', this)">VIC</div>
      <div class="state-pill" onclick="filterState('QLD', this)">QLD</div>
      <div class="state-pill" onclick="filterState('WA', this)">WA</div>
      <div class="state-pill" onclick="filterState('SA', this)">SA</div>
      <div class="state-pill" onclick="filterState('TAS', this)">TAS</div>
      <div class="state-pill" onclick="filterState('ACT', this)">ACT</div>
      <div class="state-pill" onclick="filterState('NT', this)">NT</div>
    </div>
  </div>

  <div class="container">
    <section class="section" id="directories">
      <div class="section-header">
        <h2 class="section-title">Browse Directories</h2>
        <a href="#directories" class="section-link">View all →</a>
      </div>
      <div class="dir-grid">

        <a href="/gyms" class="dir-card">
          <div class="dir-card-icon">🏋️</div>
          <div class="dir-card-name">Gyms</div>
          <div class="dir-card-desc">Find gyms, fitness centres, and CrossFit boxes near you across every state.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count" id="gym-count">{gymCount.toLocaleString()} listings</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/camping" class="dir-card">
          <div class="dir-card-icon">⛺</div>
          <div class="dir-card-name">Free Camping</div>
          <div class="dir-card-desc">Free and low-cost campsites on public land across Australia by state and region.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count" id="camping-count">{campingCount.toLocaleString()} listings</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/dog-parks" class="dir-card">
          <div class="dir-card-icon">🐕</div>
          <div class="dir-card-name">Off-Leash Dog Parks</div>
          <div class="dir-card-desc">Off-leash areas, dog beaches, and fenced dog parks by suburb and city.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count" id="dogparks-count">{dogParksCount.toLocaleString()} listings</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/markets" class="dir-card">
          <div class="dir-card-icon">🛒</div>
          <div class="dir-card-name">Markets</div>
          <div class="dir-card-desc">Farmers markets, night markets, and weekend markets across Australia.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count">Coming soon</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/pools" class="dir-card">
          <div class="dir-card-icon">🏊</div>
          <div class="dir-card-name">Swimming Pools</div>
          <div class="dir-card-desc">Public swimming pools and aquatic centres across every state.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count">Coming soon</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/skate-parks" class="dir-card">
          <div class="dir-card-icon">🛹</div>
          <div class="dir-card-name">Skate Parks</div>
          <div class="dir-card-desc">Skate parks and skateboarding areas across Australia.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count">Coming soon</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/playgrounds" class="dir-card">
          <div class="dir-card-icon">🛝</div>
          <div class="dir-card-name">Playgrounds</div>
          <div class="dir-card-desc">Playgrounds and play areas across every suburb in Australia.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count">Coming soon</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/tennis-courts" class="dir-card">
          <div class="dir-card-icon">🎾</div>
          <div class="dir-card-name">Tennis Courts</div>
          <div class="dir-card-desc">Public tennis courts across Australia by suburb and state.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count">Coming soon</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/ev-charging" class="dir-card">
          <div class="dir-card-icon">⚡</div>
          <div class="dir-card-name">EV Charging</div>
          <div class="dir-card-desc">Electric vehicle charging stations across Australia.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count">Coming soon</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

        <a href="/libraries" class="dir-card">
          <div class="dir-card-icon">📚</div>
          <div class="dir-card-name">Libraries</div>
          <div class="dir-card-desc">Public libraries across every suburb and state in Australia.</div>
          <div class="dir-card-meta">
            <span class="dir-card-count">Coming soon</span>
            <span class="dir-card-arrow">→</span>
          </div>
        </a>

      </div>
    </section>

    <hr class="divider" />
    <div class="ad-slot">Google AdSense — 728×90</div>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title" id="listings-title">Recent Listings</h2>
        <a href="#" class="section-link">View all →</a>
      </div>
      <div class="listing-grid" id="listings-grid">

        <a href="/gyms/wa/perth" class="listing-card" data-state="WA">
          <div class="listing-icon">🏋️</div>
          <div class="listing-info">
            <div class="listing-name">Joondalup Gym & Fitness</div>
            <div class="listing-loc">📍 Joondalup, WA</div>
          </div>
          <span class="listing-badge">Gym</span>
        </a>

        <a href="/camping/wa/mandurah" class="listing-card" data-state="WA">
          <div class="listing-icon">⛺</div>
          <div class="listing-info">
            <div class="listing-name">Beelu National Park Campsite</div>
            <div class="listing-loc">📍 Mundaring, WA</div>
          </div>
          <span class="listing-badge">Free Camp</span>
        </a>

        <a href="/dog-parks/wa/perth" class="listing-card" data-state="WA">
          <div class="listing-icon">🐕</div>
          <div class="listing-info">
            <div class="listing-name">Mindarie Dog Beach</div>
            <div class="listing-loc">📍 Mindarie, WA</div>
          </div>
          <span class="listing-badge">Dog Park</span>
        </a>

        <a href="/gyms/nsw/sydney" class="listing-card" data-state="NSW">
          <div class="listing-icon">🏋️</div>
          <div class="listing-info">
            <div class="listing-name">Surry Hills Fitness Club</div>
            <div class="listing-loc">📍 Surry Hills, NSW</div>
          </div>
          <span class="listing-badge">Gym</span>
        </a>

        <a href="/camping/vic/melbourne" class="listing-card" data-state="VIC">
          <div class="listing-icon">⛺</div>
          <div class="listing-info">
            <div class="listing-name">Yarra Valley Campsite</div>
            <div class="listing-loc">📍 Yarra Valley, VIC</div>
          </div>
          <span class="listing-badge">Free Camp</span>
        </a>

        <a href="/dog-parks/qld/brisbane" class="listing-card" data-state="QLD">
          <div class="listing-icon">🐕</div>
          <div class="listing-info">
            <div class="listing-name">Sandgate Dog Beach</div>
            <div class="listing-loc">📍 Sandgate, QLD</div>
          </div>
          <span class="listing-badge">Dog Park</span>
        </a>

      </div>
    </section>

    <div class="ad-slot">Google AdSense — 300×250</div>
  </div>

</Layout>

<script define:vars={{ stateCounts, gymCount, campingCount, dogParksCount, totalCount }}>
  const allCounts = { gyms: gymCount, camping: campingCount, dogParks: dogParksCount };

  function filterState(state, el) {
    document.querySelectorAll('.state-pill').forEach(p => p.classList.remove('active'));
    el.classList.add('active');

    const isAll = state === 'all';

    document.getElementById('gym-count').textContent =
      (isAll ? allCounts.gyms : stateCounts.gyms[state] || 0).toLocaleString() + ' listings';
    document.getElementById('camping-count').textContent =
      (isAll ? allCounts.camping : stateCounts.camping[state] || 0).toLocaleString() + ' listings';
    document.getElementById('dogparks-count').textContent =
      (isAll ? allCounts.dogParks : stateCounts.dogParks[state] || 0).toLocaleString() + ' listings';
    document.getElementById('total-count').textContent =
      (isAll ? totalCount : (stateCounts.gyms[state] || 0) + (stateCounts.camping[state] || 0) + (stateCounts.dogParks[state] || 0)).toLocaleString() + '+';

    const cards = document.querySelectorAll('#listings-grid .listing-card');
    cards.forEach(card => {
      card.style.display = (isAll || card.dataset.state === state) ? 'flex' : 'none';
    });

    const title = document.getElementById('listings-title');
    if (title) title.textContent = isAll ? 'Recent Listings' : `Recent Listings — ${state}`;
  }

  function heroSearch() {
    const q = document.getElementById('hero-search').value.trim();
    if (!q) return;
    window.location.href = `/gyms?q=${encodeURIComponent(q)}`;
  }

  document.getElementById('hero-search')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') heroSearch();
  });

  window.filterState = filterState;
  window.heroSearch = heroSearch;
</script>