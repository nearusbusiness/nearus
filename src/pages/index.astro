<Layout title="Australia's Local Directory" description="Every local directory you need — every suburb, every state, all in one place.">

  <section class="hero">
    <div class="hero-eyebrow">🇦🇺 Australia's Local Directory</div>
    <h1>Find anything,<br><em>near you</em> in Australia</h1>
    <p class="hero-sub">Every local directory you need — every suburb, every state, all in one place.</p>

    <div class="search-wrap">
      <input type="text" id="hero-search" placeholder="Search directories..." />
      <button class="search-btn" onclick="heroSearch()">Search</button>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num" id="total-count">{totalCount.toLocaleString()}+</div>
        <div class="hero-stat-label">Listings</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">120</div>
        <div class="hero-stat-label">Directories</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">All States</div>
        <div class="hero-stat-label">Covered</div>
      </div>
    </div>
  </section>

