const playgroundsCount = playgroundsData.length;
const tennisCount = tennisData.length;
const evCount = evData.length;
const librariesCount = librariesData.length;
const restaurantsCount = restaurantsData.length;
const cafesCount = cafesData.length;
const chemistsCount = chemistsData.length;
const petrolCount = petrolData.length;
const parksCount = parksData.length;
const beachesCount = beachesData.length;
const medicalCount = medicalData.length;
const dentistsCount = dentistsData.length;
