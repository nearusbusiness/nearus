<script define:vars={{ stateCounts, gymCount, campingCount, dogParksCount, marketsCount, poolsCount, skateParksCount, playgroundsCount, tennisCount, evCount, librariesCount, restaurantsCount, cafesCount, chemistsCount, petrolCount, parksCount, beachesCount, medicalCount, dentistsCount, vetsCount, childcareCount, supermarketsCount, hardwareCount, postOfficesCount, banksCount, petshopsCount, bakeriesCount, hairdressersCount, carWashesCount, mechanicsCount, bottleShopsCount, optometristsCount, physiotherapyCount, fastFoodCount, pizzaCount, chineseCount, indianCount, sushiCount, hotelsCount, realEstateCount, gyms24hrCount, breakfastCafesCount, breweriesCount, dessertShopsCount, brunchSpotsCount, wineriesCount, juiceBarsCount, shoppingCentresCount, opShopsCount, giftShopsCount, thingsToDoCount, escapeRoomsCount, bowlingAlleysCount, miniGolfCount, cinemasCount, laserTagCount, yogaStudiosCount, pilatesStudiosCount, massageTherapistsCount, naturopathsCount, electriciansCount, plumbersCount, cleanersCount, locksmithsCount, tyreShopsCount, swimmingLessonsCount, kidsActivitiesCount, agedCareCount, butchersCount, floristsCount, accountantsCount, fishAndChipsCount, thaiRestaurantsCount, vietnameseRestaurantsCount, mexicanRestaurantsCount, italianRestaurantsCount, greekRestaurantsCount, kebabsCount, bubbleTeaCount, foodTrucksCount, farmersMarketsCount, nailSalonsCount, beautySalonsCount, barbersCount, carDealersCount, tanningSalonsCount, osteopathsCount, chiropractorsCount, psychologistsCount, dietitiansCount, hearingClinicsCount, paintersCount, carpentersCount, tilersCount, landscapersCount, removalistsCount, pestControlCount, solarInstallersCount, airConditioningCount, fencingCount, concretersCount, golfCoursesCount, rockClimbingCount, archeryCount, goKartingCount, axeThrowingCount, trampolineParksCount, danceStudiosCount, martialArtsCount, horseRidingCount, paintballCount, newsagentsCount, pharmaciesCount, dollarStoresCount, furnitureStoresCount, mattressStoresCount, jewellersCount, electronicsStoresCount, musicStoresCount, bookshopsCount, toyShopsCount, totalCount }}>

  const allCounts = {
    gyms: gymCount, camping: campingCount, dogParks: dogParksCount,
    markets: marketsCount, pools: poolsCount, skateParks: skateParksCount,
    playgrounds: playgroundsCount, tennis: tennisCount, ev: evCount,
    libraries: librariesCount, restaurants: restaurantsCount, cafes: cafesCount,
    chemists: chemistsCount, petrol: petrolCount, parks: parksCount,
    beaches: beachesCount, medical: medicalCount, dentists: dentistsCount,
    vets: vetsCount, childcare: childcareCount, supermarkets: supermarketsCount,
    hardware: hardwareCount, postOffices: postOfficesCount, banks: banksCount,
    petshops: petshopsCount, bakeries: bakeriesCount, hairdressers: hairdressersCount,
    carWashes: carWashesCount, mechanics: mechanicsCount, bottleShops: bottleShopsCount,
    optometrists: optometristsCount, physiotherapy: physiotherapyCount, fastFood: fastFoodCount,
    pizza: pizzaCount, chinese: chineseCount, indian: indianCount, sushi: sushiCount,
    hotels: hotelsCount, realEstate: realEstateCount, gyms24hr: gyms24hrCount
  };

  const countIds = [
    ['gym-count', 'gyms'], ['camping-count', 'camping'], ['dogparks-count', 'dogParks'],
    ['markets-count', 'markets'], ['pools-count', 'pools'], ['skateparks-count', 'skateParks'],
    ['playgrounds-count', 'playgrounds'], ['tennis-count', 'tennis'], ['ev-count', 'ev'],
    ['libraries-count', 'libraries'], ['restaurants-count', 'restaurants'], ['cafes-count', 'cafes'],
    ['chemists-count', 'chemists'], ['petrol-count', 'petrol'], ['parks-count', 'parks'],
    ['beaches-count', 'beaches'], ['medical-count', 'medical'], ['dentists-count', 'dentists'],
    ['vets-count', 'vets'], ['childcare-count', 'childcare'], ['supermarkets-count', 'supermarkets'],
    ['hardware-count', 'hardware'], ['postoffices-count', 'postOffices'], ['banks-count', 'banks'],
    ['petshops-count', 'petshops'], ['bakeries-count', 'bakeries'], ['hairdressers-count', 'hairdressers'],
    ['carwashes-count', 'carWashes'], ['mechanics-count', 'mechanics'], ['bottleshops-count', 'bottleShops'],
    ['optometrists-count', 'optometrists'], ['physio-count', 'physiotherapy'], ['fastfood-count', 'fastFood'],
    ['pizza-count', 'pizza'], ['chinese-count', 'chinese'], ['indian-count', 'indian'],
    ['sushi-count', 'sushi'], ['hotels-count', 'hotels'], ['realestate-count', 'realEstate'],
    ['gyms24hr-count', 'gyms24hr'],
    ['breakfast-cafes-count', 'breakfastCafes'], ['breweries-count', 'breweries'],
    ['dessert-shops-count', 'dessertShops'], ['brunch-spots-count', 'brunchSpots'],
    ['wineries-count', 'wineries'], ['juice-bars-count', 'juiceBars'],
    ['shopping-centres-count', 'shoppingCentres'], ['op-shops-count', 'opShops'],
    ['gift-shops-count', 'giftShops'], ['things-to-do-count', 'thingsToDo'],
    ['escape-rooms-count', 'escapeRooms'], ['bowling-alleys-count', 'bowlingAlleys'],
    ['mini-golf-count', 'miniGolf'], ['cinemas-count', 'cinemas'],
    ['laser-tag-count', 'laserTag'], ['yoga-studios-count', 'yogaStudios'],
    ['pilates-studios-count', 'pilatesStudios'], ['massage-therapists-count', 'massageTherapists'],
    ['naturopaths-count', 'naturopaths'], ['electricians-count', 'electricians'],
    ['plumbers-count', 'plumbers'], ['cleaners-count', 'cleaners'],
    ['locksmiths-count', 'locksmiths'], ['tyre-shops-count', 'tyreShops'],
    ['swimming-lessons-count', 'swimmingLessons'], ['kids-activities-count', 'kidsActivities'],
    ['aged-care-count', 'agedCare'], ['butchers-count', 'butchers'],
    ['florists-count', 'florists'], ['accountants-count', 'accountants']
  ];

  function filterState(state, el) {
    document.querySelectorAll('.state-pill').forEach(p => p.classList.remove('active'));
    el.classList.add('active');
    const isAll = state === 'all';

    countIds.forEach(([id, key]) => {
      const el = document.getElementById(id);
      if (el) el.textContent = (isAll ? allCounts[key] : (stateCounts[key]?.[state] || 0)).toLocaleString() + ' listings';
    });

    const newTotal = isAll ? totalCount : Object.values(stateCounts).reduce((sum, sc) => sum + (sc[state] || 0), 0);
    const totalEl = document.getElementById('total-count');
    if (totalEl) totalEl.textContent = newTotal.toLocaleString() + '+';

    const cards = document.querySelectorAll('#listings-grid .listing-card');
    cards.forEach(card => {
      card.style.display = (isAll || card.dataset.state === state) ? 'flex' : 'none';
    });

    const title = document.getElementById('listings-title');
    if (title) title.textContent = isAll ? 'Recent Listings' : `Recent Listings — ${state}`;
  }

  function heroSearch() {
    const q = document.getElementById('hero-search').value.trim();
    if (!q) return;
    window.location.href = `/gyms?q=${encodeURIComponent(q)}`;
  }

  document.getElementById('hero-search')?.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase().trim();
    const cards = document.querySelectorAll('.dir-card');
    cards.forEach(card => {
      const name = card.querySelector('.dir-card-name')?.textContent?.toLowerCase() || '';
      const desc = card.querySelector('.dir-card-desc')?.textContent?.toLowerCase() || '';
      const keywords = card.getAttribute('data-keywords')?.toLowerCase() || '';
      card.style.display = (!q || name.includes(q) || desc.includes(q) || keywords.includes(q)) ? 'flex' : 'none';
    });
  });

  document.getElementById('hero-search')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') heroSearch();
  });

  window.filterState = filterState;
  window.heroSearch = heroSearch;
</script>