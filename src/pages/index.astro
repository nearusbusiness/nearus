  chemists: Object.fromEntries(states.map(s => [s, (chemistsData as any[]).filter(g => g.state === s).length])),
  petrol: Object.fromEntries(states.map(s => [s, (petrolData as any[]).filter(g => g.state === s).length])),
  parks: Object.fromEntries(states.map(s => [s, (parksData as any[]).filter(g => g.state === s).length])),
  beaches: Object.fromEntries(states.map(s => [s, (beachesData as any[]).filter(g => g.state === s).length])),
  medical: Object.fromEntries(states.map(s => [s, (medicalData as any[]).filter(g => g.state === s).length])),
  dentists: Object.fromEntries(states.map(s => [s, (dentistsData as any[]).filter(g => g.state === s).length])),
  vets: Object.fromEntries(states.map(s => [s, (vetsData as any[]).filter(g => g.state === s).length])),
  childcare: Object.fromEntries(states.map(s => [s, (childcareData as any[]).filter(g => g.state === s).length])),
  supermarkets: Object.fromEntries(states.map(s => [s, (supermarketsData as any[]).filter(g => g.state === s).length])),
  hardware: Object.fromEntries(states.map(s => [s, (hardwareData as any[]).filter(g => g.state === s).length])),
  postOffices: Object.fromEntries(states.map(s => [s, (postOfficesData as any[]).filter(g => g.state === s).length])),
  banks: Object.fromEntries(states.map(s => [s, (banksData as any[]).filter(g => g.state === s).length])),
