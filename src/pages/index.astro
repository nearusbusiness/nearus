const totalCount = gymCount + campingCount + dogParksCount + marketsCount + poolsCount + skateParksCount + playgroundsCount + tennisCount + evCount + librariesCount + restaurantsCount + cafesCount + chemistsCount + petrolCount + parksCount + beachesCount + medicalCount + dentistsCount + vetsCount + childcareCount + supermarketsCount + hardwareCount + postOfficesCount + banksCount + petshopsCount + bakeriesCount + hairdressersCount + carWashesCount + mechanicsCount + bottleShopsCount;

const states = ['NSW','VIC','QLD','WA','SA','TAS','ACT','NT'];

const stateCounts = {
  gyms: Object.fromEntries(states.map(s => [s, (gymsData as any[]).filter(g => g.state === s).length])),
  camping: Object.fromEntries(states.map(s => [s, (campingData as any[]).filter(g => g.state === s).length])),
