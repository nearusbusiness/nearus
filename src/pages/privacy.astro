---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Privacy Policy" description="NearUs privacy policy.">
  <div class="container" style="max-width:720px; padding: 4rem 2rem;">
    <h1 style="font-family:'Syne',sans-serif; font-size:2rem; margin-bottom:1.5rem;">Privacy Policy</h1>
    <p style="color:var(--mid); line-height:1.8; margin-bottom:1rem;">Last updated: June 2025</p>
    <h2 style="font-family:'Syne',sans-serif; font-size:1.2rem; margin:1.5rem 0 0.75rem;">What we collect</h2>
    <p style="color:var(--mid); line-height:1.8; margin-bottom:1rem;">NearUs does not collect personal information from visitors. We use Google Analytics to understand site traffic in aggregate, and Google AdSense to serve advertisements.</p>
    <h2 style="font-family:'Syne',sans-serif; font-size:1.2rem; margin:1.5rem 0 0.75rem;">Cookies</h2>
    <p style="color:var(--mid); line-height:1.8; margin-bottom:1rem;">We use cookies for analytics and advertising purposes via Google services. You can opt out of personalised advertising via <a href="https://adssettings.google.com" style="color:var(--green);">Google Ad Settings</a>.</p>
    <h2 style="font-family:'Syne',sans-serif; font-size:1.2rem; margin:1.5rem 0 0.75rem;">Third party data</h2>
    <p style="color:var(--mid); line-height:1.8; margin-bottom:1rem;">Listing data is sourced from publicly available information via Google Places API. If you believe a listing is incorrect please contact us.</p>
    <h2 style="font-family:'Syne',sans-serif; font-size:1.2rem; margin:1.5rem 0 0.75rem;">Contact</h2>
    <p style="color:var(--mid); line-height:1.8;">For privacy enquiries email <a href="mailto:hello@nearus.com.au" style="color:var(--green);">hello@nearus.com.au</a></p>
  </div>
</Layout>