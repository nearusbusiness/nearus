      <a href="/dentists">Dentists</a>
      <a href="/vets">Vets</a>
      <a href="/libraries">Libraries</a>
      <a href="/petrol-stations">Petrol Stations</a>
      <a href="/ev-charging">EV Charging</a>
      <a href="/supermarkets">Supermarkets</a>
      <a href="/hardware-stores">Hardware Stores</a>
      <a href="/bakeries">Bakeries</a>
      <a href="/bottle-shops">Bottle Shops</a>
      <a href="/mechanics">Mechanics</a>
      <a href="/hairdressers">Hairdressers</a>
      <a href="/car-washes">Car Washes</a>
      <a href="/banks">Banks</a>
      <a href="/post-offices">Post Offices</a>
      <a href="/petshops">Pet Shops</a>
      <a href="/skate-parks">Skate Parks</a>
      <a href="/playgrounds">Playgrounds</a>
      <a href="/tennis-courts">Tennis Courts</a>
      <a href="/childcare">Childcare</a>
    </div>
  </li>
  <li><a href="/about">About</a></li>
</ul>
  </nav>
  <main>
    <slot />
  </main>
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-logo">
        <span style="width:6px;height:6px;background:#40916C;border-radius:50%;display:inline-block;margin-right:6px"></span>
        NearUs
      </div>
      <ul class="footer-links">
        <li><a href="/about">About</a></li>
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <p class="footer-copy">© 2025 NearUs · Australia's Local Directory</p>
    </div>
  </footer>
</body>
</html>